HOST=0.0.0.0
PORT=1337

# Secrets (generate real values, e.g. `openssl rand -base64 16`)
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database (MySQL via docker-compose.yml — local dev/test)
DATABASE_CLIENT=mysql
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=pixtrela
DATABASE_USERNAME=pixtrela
DATABASE_PASSWORD=pixtrela
DATABASE_SSL=false

# CRM webhook integration — no extra env vars here.
# Create an API token in Strapi admin (Settings → API Tokens) with access to:
#   task (find, findOne, create, update)
#   template-task (find, findOne, create, update)
#   step (find)
# Store that token as STRAPI_SYNC_API_TOKEN in pixtrela/next/.env (not in this file).
